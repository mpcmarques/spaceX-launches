		}
	}

	header {
		display: flex;
		align-items: center;
		margin-bottom: 20px;

		img {
			height: 120px;
			width: 120px;
			object-fit: contain;
			margin-right: 20px;
			border-radius: 10px;
		}

		h1 {
			margin: 0 0 8px 0;
		}
	}

