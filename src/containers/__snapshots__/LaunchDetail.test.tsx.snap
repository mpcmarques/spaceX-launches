	background-color: #373e98;
	color: white;
	padding: 12px;
	width: 80%;
	margin-left: 10%;
	min-height: 100vh;

	.back-link {
		color: #fee36e;
		text-decoration: none;
		font-weight: bold;
		display: inline-block;
		margin-bottom: 20px;

		&:hover {
