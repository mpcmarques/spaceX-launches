                    "styles": "
	background-color: #373e98;
	color: white;
	padding: 12px;
	width: 80%;
	margin-left: 10%;
	min-height: 100vh;

	.back-link {
		color: #fee36e;
		text-decoration: none;
		font-weight: bold;
		display: inline-block;
		margin-bottom: 20px;

		&:hover {
			text-decoration: underline;
		}
	}

	header {
		display: flex;
		align-items: center;
		margin-bottom: 20px;

		img {
			height: 120px;
			width: 120px;
			object-fit: contain;
			margin-right: 20px;
			border-radius: 10px;
		}

		h1 {
			margin: 0 0 8px 0;
		}
	}

	.favorite-button {
		border: 2px solid #fee36e;
		cursor: pointer;
		background-color: transparent;
		padding: 8px 16px;
		border-radius: 10px;
		color: #fee36e;
		font-weight: bold;

		&.favorite {
			background-color: #fee36e;
			color: #373e98;
		}
	}

	.detail-section {
		background-color: #ceb92c;
		color: #2a2a2a;
		padding: 16px;
		border-radius: 10px;
		margin-bottom: 16px;

		h2 {
			margin-top: 0;
		}

		.field {
			margin-bottom: 8px;
		}

		a {
			color: #373e98;
			font-weight: bold;
		}

		ul {
			padding-left: 20px;
		}
	}

	.rocket-images {
		display: flex;
		flex-wrap: wrap;
		gap: 10px;

		img {
			height: 150px;
			object-fit: cover;
			border-radius: 10px;
		}
	}
",
